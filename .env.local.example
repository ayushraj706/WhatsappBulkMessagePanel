# ==========================================
# 1. ADMIN LOGIN (Dashboard access ke liye)
# ==========================================
# Inhe tum khud decide karo, login ke waqt yahi kaam aayenge
NEXT_PUBLIC_ADMIN_EMAIL=ayush@basekey.com
NEXT_PUBLIC_ADMIN_PASSWORD=BaseKey_Smart_2026

# ==========================================
# 2. WHATSAPP META API (Messages bhejne ke liye)
# ==========================================
# Meta Developer Console > WhatsApp > API Setup se milega
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
NEXT_PUBLIC_WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here

# SYSTEM USER wala PERMANENT TOKEN yahan dalna
NEXT_PUBLIC_WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here

# ==========================================
# 3. WEBHOOK SETUP (Replies receive karne ke liye)
# ==========================================
# Ye koi bhi random word rakh lo (e.g. BaseKey_Verify_786)
# Meta Webhook setup karte waqt yahi word kaam aayega
NEXT_PUBLIC_WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_secret_verify_token

# ==========================================
# 4. FIREBASE (Optional - Kyunki tumne hardcode kar diya hai)
# ==========================================
# Agar tumne lib/firebase.ts mein hardcode kar diya hai, toh inhe skip kar sakte ho.
